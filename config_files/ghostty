font-family = "JetBrainsMono Nerd Font"
font-size = 18
theme = biscotty
macos-titlebar-style = transparent

# Visual effects
background-opacity = 0.85
background-blur-radius = 30
window-padding-x = 15
window-padding-y = 15

# Cursor effects  
cursor-style = block
cursor-opacity = 0.8

# Font ligatures for programming symbols
font-feature = "+liga"

# Unicode width compatibility with nushell/jj
grapheme-width-method = legacy

# login shell — launch through bash login to inherit nix PATH
shell-integration = none
command = /bin/bash -l -c "exec /Users/zell/.nix-profile/bin/nu"
